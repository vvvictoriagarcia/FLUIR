# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # solo server-side, NUNCA al cliente

# ─── Mercado Pago (Fase 2) ──────────────────────────────────
MP_ACCESS_TOKEN=your-access-token                 # solo server-side
MP_PUBLIC_KEY=your-public-key                      # puede ir al cliente
MP_WEBHOOK_SECRET=your-webhook-secret              # validación HMAC del webhook

# ─── Claude API (Fase 2 — insights/logros vía n8n o server) ──
ANTHROPIC_API_KEY=your-api-key                      # solo server-side

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
